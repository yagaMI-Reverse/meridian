# Prisma CLI (migrations, seed) — superuser / system role
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/meridian"

# Runtime request path — least-privilege role, RLS enforced
APP_DATABASE_URL="postgresql://meridian_app:app_password@localhost:5433/meridian"

JWT_SECRET="change-me"
PORT=4000
SEED_ADMIN_PASSWORD="demo-password"
