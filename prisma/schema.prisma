generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST

  @@map("user_role")
}

enum LedgerEntryType {
  CHARGE
  PAYMENT
  CREDIT
  REFUND
  ADJUSTMENT

  @@map("ledger_entry_type")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED

  @@map("subscription_status")
}

enum PlanInterval {
  MONTHLY
  YEARLY

  @@map("plan_interval")
}

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users              User[]
  accounts           Account[]
  plans              Plan[]
  subscriptions      Subscription[]
  ledgerEntries      LedgerEntry[]
  idempotencyRecords IdempotencyRecord[]

  @@map("tenants")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  email        String
  passwordHash String   @map("password_hash")
  role         UserRole @default(ANALYST)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

model Account {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String
  email        String
  currency     String   @default("USD")
  balanceCents BigInt   @default(0) @map("balance_cents")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  ledgerEntries LedgerEntry[]
  subscriptions Subscription[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("accounts")
}

model Plan {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  code        String
  name        String
  amountCents Int          @map("amount_cents")
  currency    String       @default("USD")
  interval    PlanInterval @default(MONTHLY)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  subscriptions Subscription[]

  @@unique([tenantId, code])
  @@map("plans")
}

model Subscription {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  accountId        String             @map("account_id") @db.Uuid
  planId           String             @map("plan_id") @db.Uuid
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime           @map("current_period_end") @db.Timestamptz(6)
  canceledAt       DateTime?          @map("canceled_at") @db.Timestamptz(6)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([tenantId, accountId])
  @@map("subscriptions")
}

model LedgerEntry {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  accountId      String          @map("account_id") @db.Uuid
  type           LedgerEntryType
  amountCents    BigInt          @map("amount_cents")
  currency       String
  description    String
  requestKey     String?         @map("request_key")
  subscriptionId String?         @map("subscription_id") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  account Account @relation(fields: [accountId], references: [id])

  @@unique([tenantId, requestKey])
  @@index([tenantId, accountId, createdAt])
  @@map("ledger_entries")
}

model IdempotencyRecord {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  key            String
  endpoint       String
  requestHash    String    @map("request_hash")
  responseStatus Int?      @map("response_status")
  responseBody   Json?     @map("response_body")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@map("idempotency_records")
}

model ReconciliationRun {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  accountsChecked Int       @default(0) @map("accounts_checked")
  driftCount      Int       @default(0) @map("drift_count")
  drifts          Json      @default("[]")
  trigger         String    @default("manual")

  @@map("reconciliation_runs")
}
